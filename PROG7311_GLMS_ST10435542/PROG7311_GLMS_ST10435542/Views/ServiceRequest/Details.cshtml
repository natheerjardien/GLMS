@model PROG7311_GLMS_ST10435542.Models.ServiceRequest
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    Layout = "_Layout";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Details</title>
</head>
<body>

<div>
    <h2>Service Request</h2>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Contract)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Contract.ServiceLevel)
        </dd>

        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PickupAddress)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PickupAddress)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DeliveryAddress)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DeliveryAddress)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RecipientName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RecipientName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RecipientPhone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RecipientPhone)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SlaType)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SlaType)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PackageSizeCategory)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PackageSizeCategory)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cost)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cost)
        </dd>
        <dt class="col-sm-2">
            Assigned Driver
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.AssignedDriverId))
            {
                var driver = await UserManager.FindByIdAsync(Model.AssignedDriverId);
                @(driver?.UserName ?? "Unknown User")
            }
            else
            {
                <span class="text-muted">Unassigned</span>
            }
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
</div>
<div class="mt-4 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-warning">Edit</a>
    
    @if (User.IsInRole("Client")) {
        <a asp-action="MyRequests" class="btn btn-outline-dark">Back to List</a>
    }
    else if (User.IsInRole("Driver")) {
        <a asp-action="DriverIndex" class="btn btn-outline-dark">Back to List</a>
    }
    else {
        <a asp-action="Index" class="btn btn-outline-dark">Back to List</a>
    }
</div>
</body>
</html>
